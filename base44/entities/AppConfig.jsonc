{
  "name": "AppConfig",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "Config key (e.g. 'global')"
    },
    "pricing_enabled": {
      "type": "boolean",
      "default": false,
      "description": "When true, plan-based feature gating is enforced. When false, all users get full access."
    }
  },
  "required": [
    "key"
  ]
}